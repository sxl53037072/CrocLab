---
import BaseLayout from './BaseLayout.astro';
import type { Product } from '../data/products';
import type { Lang } from '../i18n/translations';
import { useTranslation, getLocalizedPath } from '../i18n/translations';

interface Props {
  product: Product;
  lang: Lang;
}

const { product, lang } = Astro.props;
const t = useTranslation(lang);
const tagline = lang === 'zh' ? product.taglineZh : product.tagline;
const description = lang === 'zh' ? product.descriptionZh : product.description;

const isApp = product.type === 'app';
const siteUrl = 'https://croclab.dev';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: product.name,
  description: product.description,
  url: `${siteUrl}/${product.id}`,
  image: `${siteUrl}${product.icon}`,
  operatingSystem: isApp ? 'iOS, Android' : 'Chrome',
  applicationCategory: isApp ? 'LifestyleApplication' : 'BrowserApplication',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD', availability: 'https://schema.org/InStock' },
  author: { '@type': 'Organization', name: 'CrocLab', url: siteUrl },
};
---

<BaseLayout title={`${product.name} — ${tagline}`} description={description} lang={lang} schema={schema}>
  <!-- Hero -->
  <section class="relative pt-28 pb-20 overflow-hidden" style={`background: linear-gradient(135deg, ${product.color}08, ${product.color}03)`}>
    <div class="relative z-10 mx-auto max-w-5xl px-6 text-center">
      <a href={getLocalizedPath('/', lang)} class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        {t('product.backToHome')}
      </a>

      <img src={product.icon} alt={product.name} class="mx-auto w-20 h-20 rounded-3xl shadow-lg mb-6 animate-slide-up" width="80" height="80" />

      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-[var(--color-text)] mb-4 animate-slide-up">
        {product.name}
      </h1>

      <p class="text-xl sm:text-2xl font-medium mb-4 animate-slide-up" style={`color: ${product.color}; animation-delay: 50ms`}>
        {tagline}
      </p>

      <p class="mx-auto max-w-2xl text-lg text-[var(--color-text-secondary)] leading-relaxed mb-10 animate-slide-up" style="animation-delay: 100ms">
        {description}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 150ms">
        {product.platforms.ios && (
          <a href={product.platforms.ios} target="_blank" rel="noopener noreferrer" class="btn-product" style={`background: ${product.color}`}>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            {t('product.appStore')}
          </a>
        )}
        {product.platforms.chrome && (
          <a href={product.platforms.chrome} target="_blank" rel="noopener noreferrer" class="btn-product" style={`background: ${product.color}`}>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.21 0 4.831 1.757 2.632 4.501l3.953 6.848A5.454 5.454 0 0 1 12 6.545h10.691A12 12 0 0 0 12 0zM1.931 5.47A11.943 11.943 0 0 0 0 12c0 6.012 4.42 10.991 10.189 11.864l3.953-6.847a5.45 5.45 0 0 1-6.865-2.29zm13.342 2.166a5.446 5.446 0 0 1 1.45 7.09l.002.001-3.952 6.848c.208.012.418.018.629.018 6.627 0 12-5.373 12-12 0-1.174-.17-2.312-.482-3.387H15.273zM12 8.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7z"/></svg>
            {t('product.addToChrome')}
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-24 bg-[var(--color-bg-secondary)]">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-text)]">{t('product.features')}</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {product.features.map((feature, i) => (
          <div class="card p-6 text-center animate-on-scroll" style={`animation-delay: ${i * 100}ms`}>
            <div class="w-12 h-12 mx-auto rounded-xl flex items-center justify-center mb-4" style={`background: ${product.color}10`}>
              <svg class="w-6 h-6" style={`color: ${product.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                {i === 0 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />}
                {i === 1 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />}
                {i === 2 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />}
                {i === 3 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />}
              </svg>
            </div>
            <h3 class="font-display text-lg font-bold text-[var(--color-text)] mb-2">
              {lang === 'zh' ? feature.titleZh : feature.title}
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              {lang === 'zh' ? feature.descriptionZh : feature.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing (if applicable) -->
  {product.pricing && (
    <section class="py-24">
      <div class="mx-auto max-w-5xl px-6 lg:px-8">
        <div class="text-center mb-16 animate-on-scroll">
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-text)]">{t('product.pricing')}</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
          <div class="card p-8 animate-on-scroll">
            <h3 class="font-display text-xl font-bold text-[var(--color-text)] mb-2">{t('product.free')}</h3>
            <p class="text-3xl font-bold text-[var(--color-text)] mb-6">$0 <span class="text-sm font-normal text-[var(--color-text-muted)]">/ forever</span></p>
            <ul class="space-y-3">
              {(lang === 'zh' ? product.pricing.freeZh : product.pricing.free).map((f: string) => (
                <li class="flex items-center gap-3 text-sm text-[var(--color-text-secondary)]">
                  <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          {product.pricing.pro && (
            <div class="card p-8 relative animate-on-scroll" style={`border-color: ${product.color}40; animation-delay: 100ms`}>
              <div class="absolute -top-3 left-6 px-3 py-1 text-xs font-bold rounded-full text-white" style={`background: ${product.color}`}>
                POPULAR
              </div>
              <h3 class="font-display text-xl font-bold text-[var(--color-text)] mb-2">{t('product.pro')}</h3>
              <p class="text-3xl font-bold text-[var(--color-text)] mb-6">{product.pricing.pro.price}</p>
              <ul class="space-y-3">
                {(lang === 'zh' ? product.pricing.pro.featuresZh : product.pricing.pro.features).map((f: string) => (
                  <li class="flex items-center gap-3 text-sm text-[var(--color-text-secondary)]">
                    <svg class="w-4 h-4 shrink-0" style={`color: ${product.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-24 bg-[var(--color-bg-secondary)]">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <div class="card-elevated p-12 animate-on-scroll">
        <img src={product.icon} alt={product.name} class="w-14 h-14 rounded-2xl mx-auto mb-4 shadow-sm" width="56" height="56" loading="lazy" />
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-[var(--color-text)] mb-4">
          {lang === 'en' ? `Ready to try ${product.name}?` : `准备好试用 ${product.name} 了吗？`}
        </h2>
        <p class="text-[var(--color-text-secondary)] mb-8 max-w-lg mx-auto">{description}</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          {product.platforms.ios && (
            <a href={product.platforms.ios} target="_blank" rel="noopener noreferrer" class="btn-product" style={`background: ${product.color}`}>
              {t('product.appStore')}
            </a>
          )}
          {product.platforms.chrome && (
            <a href={product.platforms.chrome} target="_blank" rel="noopener noreferrer" class="btn-product" style={`background: ${product.color}`}>
              {t('product.addToChrome')}
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <slot />
</BaseLayout>
