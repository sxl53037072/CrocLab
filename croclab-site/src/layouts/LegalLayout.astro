---
import BaseLayout from './BaseLayout.astro';
import type { Lang } from '../i18n/translations';
import { getLocalizedPath } from '../i18n/translations';

interface Props {
  title: string;
  productName: string;
  productId: string;
  lang: Lang;
  lastUpdated: string;
}

const { title, productName, productId, lang, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={`${title} for ${productName} by CrocLab`} lang={lang} noindex={true}>
  <section class="pt-28 pb-20">
    <div class="mx-auto max-w-3xl px-6">
      <a href={getLocalizedPath(`/${productId}`, lang)} class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Back to {productName}
      </a>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-4">{title}</h1>
      <p class="text-sm text-[var(--color-text-muted)] mb-12">Last updated: {lastUpdated}</p>
      <div class="prose max-w-none prose-headings:font-display prose-headings:text-[var(--color-text)] prose-h2:text-xl prose-h2:mt-10 prose-p:text-[var(--color-text-secondary)] prose-p:leading-relaxed prose-li:text-[var(--color-text-secondary)] prose-strong:text-[var(--color-text)] prose-a:text-[var(--color-accent)]">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>
