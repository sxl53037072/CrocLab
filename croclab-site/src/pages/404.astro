---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist." noindex={true}>
  <section class="min-h-[80vh] flex items-center justify-center">
    <div class="text-center px-6">
      <img src="/images/logo/croclab-logo.webp" alt="CrocLab" class="w-16 h-16 rounded-2xl mx-auto mb-6 shadow-lg" width="64" height="64" />
      <h1 class="font-display text-6xl sm:text-8xl font-bold text-[var(--color-text)] mb-4">404</h1>
      <p class="text-xl text-[var(--color-text-secondary)] mb-8">Oops! This page doesn't exist.</p>
      <a href="/" class="btn-primary">
        Back to Home
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
