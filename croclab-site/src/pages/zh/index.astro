---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import BlogCard from '../../components/BlogCard.astro';
import { products, getAppProducts, getExtensionProducts } from '../../data/products';
import { useTranslation } from '../../i18n/translations';
import type { Lang } from '../../i18n/translations';

const lang: Lang = 'zh';
const t = useTranslation(lang);
const apps = getAppProducts();
const extensions = getExtensionProducts();

const blogPosts = [
  { title: '2026 年 7 款最佳睡眠白噪音 App 对比评测', description: '我们实测了 20+ 款睡眠音效 App，为你挑出最好的 7 款。', slug: 'best-sleep-sounds-app-2026', date: '2026-04-22', readTime: 10, tag: '睡眠' },
  { title: '如何 5 分钟内入睡 — 10 种科学方法', description: '难以入睡？这 10 种经过科学验证的技巧可以帮你更快入睡。', slug: 'how-to-fall-asleep-fast', date: '2026-04-21', readTime: 9, tag: '睡眠' },
  { title: '2026 年深度工作的 5 种最佳番茄工作法技巧', description: '探索最有效的番茄工作法技巧，帮助你实现深度专注。', slug: 'best-pomodoro-techniques-2026', date: '2026-04-20', readTime: 8, tag: '效率' },
];
---

<BaseLayout title="CrocLab — 打造让数字生活更简单的工具" description="CrocLab 是一个创意技术工作室，专注打造高品质的应用和浏览器扩展。" lang={lang}>
  <section class="relative min-h-[90vh] flex items-center overflow-hidden pt-16">
    <div class="absolute inset-0">
      <img src="/images/blog/office-hero.webp" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-white/95 via-white/85 to-white/60"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-white/30 via-transparent to-white"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 w-full">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[var(--color-bg-tertiary)] border border-[var(--color-border)] mb-8">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          <span class="text-xs font-medium text-[var(--color-text-secondary)]">{t('hero.tagline')}</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight mb-6 text-[var(--color-text)] animate-slide-up">
          打造让数字生活<span class="gradient-text">更简单</span>的工具。
        </h1>
        <p class="max-w-xl text-lg text-[var(--color-text-secondary)] leading-relaxed mb-10 animate-slide-up" style="animation-delay: 100ms">{t('hero.description')}</p>
        <div class="flex flex-col sm:flex-row items-start gap-4 animate-slide-up" style="animation-delay: 200ms">
          <a href="#products" class="btn-primary">{t('hero.cta')}<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg></a>
          <a href="/zh/about" class="btn-secondary">{t('nav.about')}<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg></a>
        </div>
        <div class="mt-14 flex items-center gap-6 animate-fade-in" style="animation-delay: 400ms">
          <div class="flex -space-x-2">
            {products.map((p) => (<img src={p.icon} alt={p.name} class="w-10 h-10 rounded-xl border-2 border-white shadow-sm" />))}
          </div>
          <div>
            <div class="text-sm font-semibold text-[var(--color-text)]">{products.length} 款产品</div>
            <div class="text-xs text-[var(--color-text-muted)]">应用 & 浏览器扩展</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="products" class="py-24 lg:py-32 bg-[var(--color-bg-secondary)]">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-3">{t('products.apps')}</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-4">{t('products.title')}</h2>
        <p class="mx-auto max-w-xl text-[var(--color-text-secondary)]">{t('products.subtitle')}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 mb-24">
        {apps.map((p, i) => (<ProductCard product={p} lang={lang} index={i} />))}
      </div>
      <div id="extensions" class="text-center mb-16 animate-on-scroll">
        <p class="text-sm font-semibold uppercase tracking-widest text-emerald-600 mb-3">{t('products.extensions')}</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-4">浏览器扩展</h2>
        <p class="mx-auto max-w-xl text-[var(--color-text-secondary)]">增强日常工作流程的强大浏览器工具。</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {extensions.map((p, i) => (<ProductCard product={p} lang={lang} index={i + 2} />))}
      </div>
    </div>
  </section>

  <div class="section-divider mx-auto max-w-7xl"></div>

  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between gap-4 mb-12 animate-on-scroll">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-purple-600 mb-3">{t('nav.blog')}</p>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-text)]">{t('blog.title')}</h2>
          <p class="mt-2 text-[var(--color-text-secondary)] max-w-lg">{t('blog.subtitle')}</p>
        </div>
        <a href="/zh/blog" class="btn-secondary text-sm shrink-0">{t('blog.viewAll')}<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg></a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {blogPosts.map((post) => (<BlogCard {...post} lang={lang} />))}
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-[var(--color-text)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10"><img src="/images/blog/team-working.webp" alt="" class="w-full h-full object-cover" /></div>
    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center animate-on-scroll">
      <img src="/images/logo/croclab-logo.png" alt="CrocLab" class="w-16 h-16 rounded-2xl mx-auto mb-6 shadow-lg" />
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">准备好提升你的效率了吗？</h2>
      <p class="mx-auto max-w-xl text-white/70 mb-8">探索我们的产品，找到适合你工作流程的完美工具。</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#products" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm bg-white text-[var(--color-text)] hover:bg-gray-100 transition-all">{t('hero.cta')}</a>
        <a href="/zh/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white border border-white/30 hover:bg-white/10 transition-all">{t('nav.contact')}</a>
      </div>
    </div>
  </section>
</BaseLayout>
