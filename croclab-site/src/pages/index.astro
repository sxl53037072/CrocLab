---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { products, getAppProducts, getExtensionProducts } from '../data/products';
import { useTranslation } from '../i18n/translations';
import type { Lang } from '../i18n/translations';

const lang: Lang = 'en';
const t = useTranslation(lang);

const apps = getAppProducts();
const extensions = getExtensionProducts();

const blogPosts = [
  {
    title: '5 Best Pomodoro Techniques for Deep Work in 2026',
    description: 'Discover the most effective Pomodoro techniques that will help you achieve deep focus and get more done every day.',
    slug: 'best-pomodoro-techniques-2026',
    date: '2026-04-20',
    readTime: 8,
    tag: 'Productivity',
  },
  {
    title: 'Top Chrome Extensions Every Developer Needs',
    description: 'A curated list of must-have Chrome extensions that will supercharge your development workflow.',
    slug: 'chrome-extensions-for-developers',
    date: '2026-04-15',
    readTime: 6,
    tag: 'Development',
  },
  {
    title: 'How White Noise Improves Your Sleep Quality',
    description: 'The science behind ambient sounds and how they can help you fall asleep faster and sleep deeper.',
    slug: 'white-noise-sleep-quality',
    date: '2026-04-10',
    readTime: 5,
    tag: 'Sleep',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'CrocLab',
  url: 'https://croclab.dev',
  logo: 'https://croclab.dev/images/logo/croclab-logo.png',
  description: 'Independent developer studio crafting focused apps and browser extensions.',
};
---

<BaseLayout
  title="CrocLab — Crafting Tools for a Simpler Digital Life"
  description="CrocLab is an independent developer studio building focused, beautiful apps and browser extensions. Explore FocusCroc, DreamTone, AiDock, DevCodec and more."
  lang={lang}
  schema={schema}
>
  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden pt-16">
    <!-- Hero Background Image -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1920&q=80&auto=format"
        alt=""
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-white/95 via-white/85 to-white/60"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-white/30 via-transparent to-white"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 w-full">
      <div class="max-w-2xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[var(--color-bg-tertiary)] border border-[var(--color-border)] mb-8 animate-fade-in">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          <span class="text-xs font-medium text-[var(--color-text-secondary)]">{t('hero.tagline')}</span>
        </div>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight mb-6 text-[var(--color-text)] animate-slide-up">
          Crafting tools that make your digital life
          <span class="gradient-text"> simpler.</span>
        </h1>

        <p class="max-w-xl text-lg text-[var(--color-text-secondary)] leading-relaxed mb-10 animate-slide-up" style="animation-delay: 100ms">
          {t('hero.description')}
        </p>

        <div class="flex flex-col sm:flex-row items-start gap-4 animate-slide-up" style="animation-delay: 200ms">
          <a href="#products" class="btn-primary">
            {t('hero.cta')}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
          <a href="/about" class="btn-secondary">
            {t('nav.about')}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Product Icons Row -->
        <div class="mt-14 flex items-center gap-6 animate-fade-in" style="animation-delay: 400ms">
          <div class="flex -space-x-2">
            {products.map((p) => (
              <img src={p.icon} alt={p.name} class="w-10 h-10 rounded-xl border-2 border-white shadow-sm" />
            ))}
          </div>
          <div>
            <div class="text-sm font-semibold text-[var(--color-text)]">{products.length} Products</div>
            <div class="text-xs text-[var(--color-text-muted)]">Apps & Chrome Extensions</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section: Apps -->
  <section id="products" class="py-24 lg:py-32 bg-[var(--color-bg-secondary)]">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-3">{t('products.apps')}</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-4">{t('products.title')}</h2>
        <p class="mx-auto max-w-xl text-[var(--color-text-secondary)]">{t('products.subtitle')}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 mb-24">
        {apps.map((product, i) => (
          <ProductCard product={product} lang={lang} index={i} />
        ))}
      </div>

      <div id="extensions" class="text-center mb-16 animate-on-scroll">
        <p class="text-sm font-semibold uppercase tracking-widest text-emerald-600 mb-3">{t('products.extensions')}</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-4">Chrome Extensions</h2>
        <p class="mx-auto max-w-xl text-[var(--color-text-secondary)]">
          Powerful browser tools that enhance your daily workflow.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {extensions.map((product, i) => (
          <ProductCard product={product} lang={lang} index={i + 2} />
        ))}
      </div>
    </div>
  </section>

  <!-- Showcase Section with large image -->
  <section class="relative py-24 overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="animate-on-scroll">
          <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-3">Why CrocLab</p>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-6">
            Built with care,<br/>designed for everyone.
          </h2>
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-8">
            Every product we build starts with a real problem. We focus on simplicity, privacy, and delightful user experiences — no bloat, no data selling, just tools that work.
          </p>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-[var(--color-accent-soft)] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-[var(--color-text)] mb-1">Quality Over Quantity</h3>
                <p class="text-sm text-[var(--color-text-muted)]">Every product is crafted with attention to detail and user experience.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-[var(--color-text)] mb-1">Privacy First</h3>
                <p class="text-sm text-[var(--color-text-muted)]">Your data stays on your device. We never sell your information.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-[var(--color-text)] mb-1">Built for the World</h3>
                <p class="text-sm text-[var(--color-text-muted)]">Available globally with multi-language support.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="animate-on-scroll relative" style="animation-delay: 200ms">
          <img
            src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=800&q=80&auto=format"
            alt="Workspace"
            class="rounded-3xl shadow-2xl w-full"
          />
          <div class="absolute -bottom-6 -left-6 card-elevated p-4 flex items-center gap-3 animate-on-scroll" style="animation-delay: 400ms">
            <div class="flex -space-x-1.5">
              {products.slice(0, 3).map((p) => (
                <img src={p.icon} alt="" class="w-8 h-8 rounded-lg border-2 border-white" />
              ))}
            </div>
            <div>
              <div class="text-sm font-semibold text-[var(--color-text)]">{products.length}+ Products</div>
              <div class="text-xs text-[var(--color-text-muted)]">and growing</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider mx-auto max-w-7xl"></div>

  <!-- Blog Preview Section -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between gap-4 mb-12 animate-on-scroll">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-purple-600 mb-3">{t('nav.blog')}</p>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-[var(--color-text)]">{t('blog.title')}</h2>
          <p class="mt-2 text-[var(--color-text-secondary)] max-w-lg">{t('blog.subtitle')}</p>
        </div>
        <a href="/blog" class="btn-secondary text-sm shrink-0">
          {t('blog.viewAll')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {blogPosts.map((post) => (
          <BlogCard {...post} lang={lang} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 lg:py-32 bg-[var(--color-text)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=1920&q=80&auto=format" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
      <div class="animate-on-scroll">
        <img src="/images/logo/croclab-logo.png" alt="CrocLab" class="w-16 h-16 rounded-2xl mx-auto mb-6 shadow-lg" />
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
          Ready to boost your productivity?
        </h2>
        <p class="mx-auto max-w-xl text-white/70 mb-8">
          Explore our products and find the perfect tools for your workflow.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#products" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm bg-white text-[var(--color-text)] hover:bg-gray-100 transition-all duration-300 hover:-translate-y-0.5">
            {t('hero.cta')}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
            </svg>
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white border border-white/30 hover:bg-white/10 transition-all duration-300">
            {t('nav.contact')}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
