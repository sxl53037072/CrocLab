---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  type?: string;
  noindex?: boolean;
  schema?: Record<string, unknown>;
}

const {
  title,
  description,
  ogImage = '/og-image.png',
  canonicalUrl,
  type = 'website',
  noindex = false,
  schema,
} = Astro.props;

const siteUrl = 'https://croclab.dev';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const canonical = canonicalUrl || `${siteUrl}${Astro.url.pathname}`;
const fullTitle = title.includes('CrocLab') ? title : `${title} | CrocLab`;
const isZh = Astro.url.pathname.startsWith('/zh');
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

{!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}
{noindex && <meta name="robots" content="noindex, nofollow" />}

<meta name="theme-color" content="#ffffff" />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content="CrocLab" />
<meta property="og:locale" content={isZh ? 'zh_CN' : 'en_US'} />
{isZh && <meta property="og:locale:alternate" content="en_US" />}
{!isZh && <meta property="og:locale:alternate" content="zh_CN" />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@laughallwind" />
<meta name="twitter:creator" content="@laughallwind" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />

{schema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
)}
